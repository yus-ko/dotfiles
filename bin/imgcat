#!/bin/bash
# iTerm2 inline image protocol でターミナルに画像を表示する
# tmux内ではクライアントのttyに直接書き込んでtmuxをバイパスする

SIZE=$(wc -c < "$1")
DATA=$(base64 < "$1" | tr -d '\n')

if [ -n "$TMUX" ]; then
  TMUX_TTY=$(tmux list-clients -F "#{client_tty}" | head -1)
  # ステータスバーを非表示にしてカーソルを先頭へ移動してから画像表示
  tmux set-option -g status off
  printf '\033[H\033]1337;File=inline=1;size=%d:%s\a\n' "$SIZE" "$DATA" > "$TMUX_TTY"
  # キー入力でtmux表示を復元
  read -n1 -rsp "[imgcat] Press any key to restore tmux..." 2>/dev/null
  tmux set-option -g status on
  tmux refresh-client
else
  printf '\033]1337;File=inline=1;size=%d:%s\a\n' "$SIZE" "$DATA"
fi
