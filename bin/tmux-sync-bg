#!/bin/bash
# OSC 11でターミナルの背景色を問い合わせ、少し明るくしてtmuxのフォーカスペイン背景色に設定する
# wezterm等のOSC 11対応ターミナルで動作する

[ -z "$TMUX" ] && exit 0

# tmuxのptyを取得してターミナルと直接通信する
tty=$(tmux display-message -p '#{client_tty}')
[ -z "$tty" ] && exit 0

# tmux内からはDCSパススルーで外側のターミナルに問い合わせる
oldstty=$(stty -g -F "$tty")
stty raw -echo min 0 time 2 -F "$tty"

printf '\ePtmux;\e\e]11;?\a\e\\' > "$tty"

response=""
while IFS= read -r -n1 -t 1 char <"$tty"; do
  response+="$char"
  [[ "$char" == $'\a' || "$char" == '\' ]] && break
done

stty "$oldstty" -F "$tty"

# rgb:RRRR/GGGG/BBBB 形式をパース
if [[ "$response" =~ rgb:([0-9a-fA-F]+)/([0-9a-fA-F]+)/([0-9a-fA-F]+) ]]; then
  # 4桁の場合は上位2桁を使用（8bitに変換）
  r=${BASH_REMATCH[1]:0:2}
  g=${BASH_REMATCH[2]:0:2}
  b=${BASH_REMATCH[3]:0:2}

  r=$((16#$r))
  g=$((16#$g))
  b=$((16#$b))

  # 少し明るくする
  offset=25
  r=$(( r + offset > 255 ? 255 : r + offset ))
  g=$(( g + offset > 255 ? 255 : g + offset ))
  b=$(( b + offset > 255 ? 255 : b + offset ))

  bright=$(printf "#%02x%02x%02x" $r $g $b)
  tmux set -g window-active-style "bg=$bright"
fi
